# prajna — top-level test entry (referenced by cyrius.cyml [build].test).
# M1:   gate the scalar second-order meta-gradient against finite differences.
# M2.a: gate the linear-MAML (rosnet) second-order meta-gradient against FD.

include "lib/syscalls.cyr"
include "lib/tyche.cyr"
include "lib/rosnet.cyr"
include "src/meta.cyr"
include "src/maml.cyr"
include "src/mlp.cyr"
include "src/mamlnl.cyr"
include "src/sine.cyr"
include "src/lopt.cyr"

fn main() {
    alloc_init();

    # ---- M1: scalar meta-gradient ----
    var theta = f64_div(f64_from(1), f64_from(2));      # 0.5
    assert(gate_pass(theta), "M1: scalar meta-grad matches finite-diff (FD gate)");
    assert(second_order_observable(theta), "M1: FOMAML differs from FD (2nd-order term is real)");
    var before = meta_loss(theta);
    var after  = meta_loss(f64_sub(theta, meta_grad_full(theta)));
    assert(f64_le(after, before), "M1: meta-loss descends under the full meta-gradient");

    # ---- M2.a: linear-MAML meta-gradient on rosnet (coupled W[3], b) ----
    maml_init();
    maml_meta_grad();
    assert(maml_gate(), "M2.a: rosnet meta-grad matches finite-diff on all params");
    assert(maml_2nd_observable(), "M2.a: FOMAML differs from FD (2nd-order term is real)");
    var mb = maml_meta_loss();
    maml_meta_grad();
    var mlr = f64_div(f64_from(3), f64_from(10));
    t_axpy(M_W, M_oW, f64_sub(f64_from(0), mlr), maml_k());
    store64(M_b, f64_sub(load64(M_b), f64_mul(mlr, load64(M_ob))));
    var ma = maml_meta_loss();
    assert(f64_le(ma, mb), "M2.a: meta-loss descends under the full meta-gradient");

    # ---- M2.b.1: tanh MLP first-order backprop on rosnet ----
    mlp_init();
    assert(mlp_grad_gate(), "M2.b.1: MLP hand-derived backprop matches finite-diff");

    # ---- M2.b.2: nonlinear MAML + R-operator second-order meta-gradient ----
    nm_init();
    assert(nm_grad_gate(), "M2.b.2: ∇Ls matches finite-diff (gate 1)");
    assert(nm_hvp_gate(), "M2.b.2: R-operator HVP matches FD-of-gradient (gate 2)");
    assert(nm_meta_grad_gate(), "M2.b.2: 2nd-order meta-grad matches FD-of-meta-loss (gate 3)");
    assert(nm_2nd_observable(), "M2.b.2: FOMAML differs from FD (θ-dependent 2nd-order term is real)");

    # ---- M2.c.1: sovereign f64_sin + engine generalization at the sine config ----
    assert(sine_validate(), "M2.c.1: f64_sin valid at known angles");
    assert(sine_sanity(), "M2.c.1: engine FD-gates pass at sine config (K=1,H=8)");

    # ---- M2.c.2: meta-training reduces held-out few-shot adaptation loss ----
    nm_config(1, 16, 8, 8);
    sine_opt_init();
    rng_seed(1001); sine_init_params();
    var mcb = sine_eval(10, 7777);
    var ch = 0;
    while (ch < 3) {
        rng_seed(2002 + ch);
        var ss = 0;
        while (ss < 100) { sine_train_batch_step(12, f64_div(f64_from(5), f64_from(100))); ss = ss + 1; }
        ch = ch + 1;
    }
    assert(f64_le(sine_eval(10, 7777), mcb), "M2.c.2: meta-training reduces held-out adapt loss");

    # ---- M2.c.3: the FOMAML (first-order) training path also meta-learns ----
    nm_config(1, 16, 6, 6);
    sine_opt_init();
    rng_seed(1001); sine_init_params();
    var fb = sine_eval(8, 7777);
    rng_seed(2002);
    var fs = 0;
    while (fs < 150) { sine_train_batch_step_m(12, f64_div(f64_from(5), f64_from(100)), 0); fs = fs + 1; }
    assert(f64_le(sine_eval(8, 7777), fb), "M2.c.3: FOMAML meta-training also reduces held-out loss");

    # ---- M3.a: learned-optimizer BPTT meta-gradient ----
    lo_init();
    assert(lo_gate(), "M3.a: learned-optimizer BPTT meta-grad matches finite-diff");

    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
