# prajna — top-level test entry (referenced by cyrius.cyml [build].test).
# M1:   gate the scalar second-order meta-gradient against finite differences.
# M2.a: gate the linear-MAML (rosnet) second-order meta-gradient against FD.

include "lib/syscalls.cyr"
include "lib/tyche.cyr"
include "lib/rosnet.cyr"
include "lib/akshara.cyr"
include "src/fdgate.cyr"
include "src/meta.cyr"
include "src/maml.cyr"
include "src/mlp.cyr"
include "src/mamlnl.cyr"
include "src/sine.cyr"
include "src/lopt.cyr"
include "src/lrnn.cyr"
include "src/text.cyr"

# akshara references _putc/puts (its emit/debug paths); provide them for this build unit.
fn _putc(ch): i64 { var b[8]; store8(&b, ch); sys_write(1, &b, 1); return 0; }
fn puts(s): i64 { var n = 0; while (load8(s + n) != 0) { n = n + 1; } print(s, n); return 0; }

fn main() {
    alloc_init();

    # ---- 0.6.0: NaN-safe FD gates (audit N-1) — the guard must REJECT non-finite diffs ----
    var fg_nan = f64_div(f64_from(0), f64_from(0));
    var fg_inf = f64_div(f64_from(1), f64_from(0));
    var fg_tol = f64_div(f64_from(1), f64_from(10000));
    assert(fd_finite(f64_from(5)), "fdgate: finite value passes fd_finite");
    assert(fd_finite(fg_nan) == 0, "fdgate: NaN rejected by fd_finite");
    assert(fd_finite(fg_inf) == 0, "fdgate: +Inf rejected by fd_finite");
    assert(fd_finite(f64_sub(f64_from(0), fg_inf)) == 0, "fdgate: -Inf rejected by fd_finite");
    assert(fd_match(f64_from(3), f64_from(3), fg_tol), "fdgate: equal values match");
    assert(fd_match(fg_nan, f64_from(3), fg_tol) == 0, "fdgate: NaN gradient FAILS the gate (was: passed)");
    assert(fd_match(fg_inf, f64_from(3), fg_tol) == 0, "fdgate: Inf gradient FAILS the gate");

    # ---- M1: scalar meta-gradient ----
    var theta = f64_div(f64_from(1), f64_from(2));      # 0.5
    assert(gate_pass(theta), "M1: scalar meta-grad matches finite-diff (FD gate)");
    assert(second_order_observable(theta), "M1: FOMAML differs from FD (2nd-order term is real)");
    var before = meta_loss(theta);
    var after  = meta_loss(f64_sub(theta, meta_grad_full(theta)));
    assert(f64_le(after, before), "M1: meta-loss descends under the full meta-gradient");

    # ---- M2.a: linear-MAML meta-gradient on rosnet (coupled W[3], b) ----
    maml_init();
    maml_meta_grad();
    assert(maml_gate(), "M2.a: rosnet meta-grad matches finite-diff on all params");
    assert(maml_2nd_observable(), "M2.a: FOMAML differs from FD (2nd-order term is real)");
    var mb = maml_meta_loss();
    maml_meta_grad();
    var mlr = f64_div(f64_from(3), f64_from(10));
    t_axpy(M_W, M_oW, f64_sub(f64_from(0), mlr), maml_k());
    store64(M_b, f64_sub(load64(M_b), f64_mul(mlr, load64(M_ob))));
    var ma = maml_meta_loss();
    assert(f64_le(ma, mb), "M2.a: meta-loss descends under the full meta-gradient");

    # ---- M2.b.1: tanh MLP first-order backprop on rosnet ----
    mlp_init();
    assert(mlp_grad_gate(), "M2.b.1: MLP hand-derived backprop matches finite-diff");

    # ---- M2.b.2: nonlinear MAML + R-operator second-order meta-gradient ----
    nm_init();
    assert(nm_grad_gate(), "M2.b.2: ∇Ls matches finite-diff (gate 1)");
    assert(nm_hvp_gate(), "M2.b.2: R-operator HVP matches FD-of-gradient (gate 2)");
    assert(nm_meta_grad_gate(), "M2.b.2: 2nd-order meta-grad matches FD-of-meta-loss (gate 3)");
    assert(nm_2nd_observable(), "M2.b.2: FOMAML differs from FD (θ-dependent 2nd-order term is real)");

    # ---- M2.c.1: sovereign f64_sin + engine generalization at the sine config ----
    assert(sine_validate(), "M2.c.1: f64_sin valid at known angles");
    assert(sine_sanity(), "M2.c.1: engine FD-gates pass at sine config (K=1,H=8)");

    # ---- M2.c.2: meta-training reduces held-out few-shot adaptation loss ----
    nm_config(1, 16, 8, 8);
    sine_opt_init();
    rng_seed(1001); sine_init_params();
    var mcb = sine_eval(10, 7777);
    var ch = 0;
    while (ch < 3) {
        rng_seed(2002 + ch);
        var ss = 0;
        while (ss < 100) { sine_train_batch_step(12, f64_div(f64_from(5), f64_from(100))); ss = ss + 1; }
        ch = ch + 1;
    }
    assert(f64_le(sine_eval(10, 7777), mcb), "M2.c.2: meta-training reduces held-out adapt loss");

    # ---- M2.c.3: the FOMAML (first-order) training path also meta-learns ----
    nm_config(1, 16, 6, 6);
    sine_opt_init();
    rng_seed(1001); sine_init_params();
    var fb = sine_eval(8, 7777);
    rng_seed(2002);
    var fs = 0;
    while (fs < 150) { sine_train_batch_step_m(12, f64_div(f64_from(5), f64_from(100)), 0); fs = fs + 1; }
    assert(f64_le(sine_eval(8, 7777), fb), "M2.c.3: FOMAML meta-training also reduces held-out loss");

    # ---- M3.a: learned-optimizer BPTT meta-gradient ----
    lo_init();
    assert(lo_gate(), "M3.a: learned-optimizer BPTT meta-grad matches finite-diff");

    # ---- M3.b: meta-training improves the optimizer + it beats fixed-lr SGD ----
    lo_opt_init();
    var lob = lo_eval_learned(15, 7777);
    var loc = 0;
    while (loc < 3) {
        rng_seed(3000 + loc);
        var lss = 0;
        while (lss < 100) { lo_train_step_batch(12, f64_div(f64_from(1), f64_from(100))); lss = lss + 1; }
        loc = loc + 1;
    }
    var loa = lo_eval_learned(15, 7777);
    assert(f64_le(loa, lob), "M3.b: meta-training improves the learned optimizer");
    assert(f64_le(loa, lo_eval_sgd(15, 7777, f64_div(f64_from(3), f64_from(10)))),
           "M3.b: learned optimizer beats fixed-lr SGD");

    # ---- M3.c: recurrent-optimizer two-recurrence BPTT + meta-train ----
    lo_set_task(f64_from(1), f64_from(2), f64_from(0));
    lr_init();
    assert(lr_gate(), "M3.c: recurrent-optimizer BPTT matches finite-diff");
    var rcb = lr_eval_learned(15, 7777);
    var rci = 0;
    while (rci < 3) {
        rng_seed(4000 + rci);
        var rcs = 0;
        while (rcs < 100) { lr_train_step_batch(12, f64_div(f64_from(1), f64_from(100))); rcs = rcs + 1; }
        rci = rci + 1;
    }
    assert(f64_le(lr_eval_learned(15, 7777), rcb), "M3.c: recurrent optimizer meta-trains (loss drops)");

    # ---- M4.a: next-token LM on akshara-tokenized text — backprop FD-gated ----
    tx_init("hello world", 11, 4);
    assert(tx_gate(), "M4.a: next-token LM (embedding+head+softmax-xent) backprop matches FD");

    # ---- M4.b: MAML over text shift-tasks reduces held-out few-shot NLL ----
    tm_init();
    var tma = f64_from(3);                               # inner lr 3.0
    var tmb = tm_eval(12, 7777, tma);
    var tmc = 0;
    while (tmc < 3) {
        rng_seed(5000 + tmc);
        var tms = 0;
        while (tms < 100) { tm_train_step(16, f64_div(f64_from(2), f64_from(10)), tma); tms = tms + 1; }
        tmc = tmc + 1;
    }
    assert(f64_le(tm_eval(12, 7777, tma), tmb), "M4.b: text MAML reduces held-out few-shot NLL");

    # ---- M5: continual learning — backprop FD-gated; replay prevents forgetting ----
    ec_init();
    assert(ec_grad_gate(), "M5: MLP backprop matches finite-diff");
    var efit = f64_div(f64_from(3), f64_from(10));
    var eblr = f64_div(f64_from(3), f64_from(100));
    ec_set_a(); ec_train(2000, efit, 0, f64_from(0));
    ec_snapshot();
    ec_reset(); ec_set_b(); ec_train(3000, eblr, 0, f64_from(0));
    var e_naive = ec_loss_a();
    ec_reset(); ec_set_ab(); ec_train(3000, eblr, 0, f64_from(0));
    assert(f64_le(ec_loss_a(), e_naive), "M5: experience replay retains task A better than naive");

    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
